# ── Backend (Render) ─────────────────────────────────
PORT=8080
HOST=0.0.0.0
WEB_ORIGIN=http://localhost:3000

# Optional — system runs without these (in-memory fallback)
REDIS_URL=                              # rediss://default:<token>@<host>.upstash.io:6379
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI providers — optional, fail-soft to deterministic fallbacks
COHERE_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# External APIs — optional, app degrades to bundled sample catalog
TMDB_API_KEY=

# Demo mode controls
DEMO_MODE=true
DEMO_USERS=120
DEMO_EVENT_RATE_HZ=8

# ── Frontend (Vercel) ────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
